# ====================================================
# CDIEMApp — Variables de entorno del Backend
# Copia este archivo como .env y completa los valores
# ====================================================

# Puerto del servidor (default: 3001)
PORT=3001

# Secret para firmar JWT — CAMBIA ESTO en producción (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secret_seguro_de_al_menos_32_caracteres

# Origen permitido por CORS (dominio del frontend)
# Desarrollo:   http://localhost:3000
# Producción:   https://tu-dominio.cl
CORS_ORIGIN=http://localhost:3000

# Entorno de ejecución
NODE_ENV=development

# ====================================================
# Base de Datos
# ====================================================

# OPCIÓN A — SQLite local (por defecto, sin configuración extra)
# El archivo se crea automáticamente en la raíz del proyecto.
# Cambiar la ruta si es necesario:
# DB_PATH=/ruta/absoluta/al/database.sqlite

# OPCIÓN B — PostgreSQL gratuito en la nube (cuando tengas servidor/dominio)
# Proveedores gratuitos sin tarjeta de crédito:
#   Neon      → https://neon.tech      (recomendado — serverless, 0.5 GB gratis)
#   Supabase  → https://supabase.com   (500 MB, incluye auth y storage)
#   Aiven     → https://aiven.io       (1 GB RAM, 5 GB disco, siempre gratis)
#
# Pasos:
# 1. Crear cuenta en alguno de los proveedores
# 2. Crear proyecto y copiar el connection string
# 3. Desmarcar las siguientes líneas:
#
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db
#
# Luego instalar el driver de PostgreSQL:
#   cd backend && npm install pg pg-hstore
# Y ejecutar: node init-db.js

# ====================================================
# Configuración de Email (para envío de reportes)
# Usa una "App Password" de Gmail, no tu contraseña normal
# ====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@cdiem.cl
