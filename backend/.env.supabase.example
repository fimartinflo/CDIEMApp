# ──────────────────────────────────────────────────────────────────────────────
# CDIEMApp — Configuración Supabase (PostgreSQL cloud)
#
# PASOS PARA OBTENER LA URL:
#   1. Ir a https://supabase.com → Iniciar sesión o crear cuenta (gratis)
#   2. Crear nuevo proyecto (elegir región más cercana, ej. South America)
#   3. Supabase Dashboard → Project Settings → Database
#   4. Bajar a "Connection pooling" → Mode: Transaction → copiar "Connection string"
#      (usar puerto 6543, NO el 5432 directo, para evitar límite de conexiones)
#   5. Reemplazar [YOUR-PASSWORD] en la URL con la contraseña del proyecto
#
# FORMATO DE LA URL:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# EJEMPLO:
#   DATABASE_URL=postgresql://postgres.abcxyzref:MiPassword123@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# ──────────────────────────────────────────────────────────────────────────────

DB_DIALECT=postgres
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Puerto del servidor backend (sin cambios)
PORT=3001

# JWT — cambiar por un string aleatorio seguro (mínimo 32 caracteres)
JWT_SECRET=cdiem_secret_CAMBIAR_EN_PRODUCCION_min32chars

# CORS — URL del frontend (en local, dejar como está)
CORS_ORIGIN=http://localhost:3000

# Entorno
NODE_ENV=production
